{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.0",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "node": "20.18.0",
      "env": {
        "NODE_ENV": "production",
        "EXPO_OPTIMIZE": "true",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_FORCE": "true",
        "NPM_CONFIG_AUDIT": "false"
      },
      "cache": {
        "disabled": true
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest"
      }
    },
    "preview-small": {
      "extends": "preview",
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      }
    },
    "android-optimized": {
      "node": "20.18.0",
      "env": {
        "NODE_ENV": "production",
        "EXPO_OPTIMIZE": "true",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_FORCE": "true",
        "NPM_CONFIG_AUDIT": "false"
      },
      "cache": {
        "disabled": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest"
      }
    },
    "android-yarn": {
      "node": "20.18.0",
      "env": {
        "NODE_ENV": "production",
        "EXPO_OPTIMIZE": "true"
      },
      "cache": {
        "disabled": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
